// ── State summary card for the grid view ──
function StateCard({ state, rows, loginCol, disbCol, onClick }) {
  const total = rows.length;
  const loginActive = rows.filter(r => loginCol && normalize(r[loginCol]).toLowerCase() === "active").length;
  const disbActive = rows.filter(r => disbCol && normalize(r[disbCol]).toLowerCase() === "active").length;
  const bothActive = rows.filter(r => {
    const l = loginCol ? normalize(r[loginCol]).toLowerCase() : "";
    const d = disbCol ? normalize(r[disbCol]).toLowerCase() : "";
    return l === "active" && d === "active";
  }).length;
  const bothInactive = rows.filter(r => {
    const l = loginCol ? normalize(r[loginCol]).toLowerCase() : "";
    const d = disbCol ? normalize(r[disbCol]).toLowerCase() : "";
    return l === "inactive" && d === "inactive";
  }).length;
  const moderate = total - bothActive - bothInactive;
  const cities = new Set(rows.map(r => normalize(r.City)).filter(Boolean)).size;
  const zones = new Set(rows.map(r => normalize(r.ZONE_HL)).filter(Boolean)).size;
  const loginPct = total ? Math.round((loginActive / total) * 100) : 0;
  const disbPct = total ? Math.round((disbActive / total) * 100) : 0;

  return (
    <div className="state-card" onClick={() => onClick(state)}>
      <div className="state-card-header">
        <div className="state-card-name">{state}</div>
        <div className="state-card-total">{total} <span>branches</span></div>
      </div>

      <div className="state-card-stats">
        <div className="stat-pill active-pill">
          <div className="stat-num">{bothActive}</div>
          <div className="stat-lbl">Active</div>
        </div>
        <div className="stat-pill inactive-pill">
          <div className="stat-num">{bothInactive}</div>
          <div className="stat-lbl">Inactive</div>
        </div>
        <div className="stat-pill moderate-pill">
          <div className="stat-num">{Math.max(0, moderate)}</div>
          <div className="stat-lbl">Moderate</div>
        </div>
      </div>

      <div className="state-card-bars">
        <div className="bar-row">
          <span className="bar-label">Login</span>
          <div className="bar-track">
            <div className="bar-fill bar-login" style={{ width: `${loginPct}%` }} />
          </div>
          <span className="bar-pct">{loginPct}%</span>
        </div>
        <div className="bar-row">
          <span className="bar-label">Disb</span>
          <div className="bar-track">
            <div className="bar-fill bar-disb" style={{ width: `${disbPct}%` }} />
          </div>
          <span className="bar-pct">{disbPct}%</span>
        </div>
      </div>

      <div className="state-card-footer">
        <span>🏙 {cities} {cities === 1 ? "city" : "cities"}</span>
        <span>🗺 {zones} {zones === 1 ? "zone" : "zones"}</span>
        <span className="drill-hint">Click to drill →</span>
      </div>
    </div>
  );
}

// ── Detail drill-down view (branch cards) ──
function DrillView({ state, rows, loginCol, disbCol, onBack }) {
  const [expandedCities, setExpandedCities] = useState({});
  const [expandedGeos, setExpandedGeos] = useState({});

  const tree = useMemo(() => {
    const map = {};
    rows.forEach(row => {
      const city = normalize(row.City) || "Unknown";
      const geo = normalize(row.GEO_HL) || "—";
      if (!map[city]) map[city] = {};
      if (!map[city][geo]) map[city][geo] = [];
      map[city][geo].push(row);
    });
    return map;
  }, [rows]);

  const toggleCity = (key) => setExpandedCities(p => ({ ...p, [key]: !p[key] }));
  const toggleGeo = (key) => setExpandedGeos(p => ({ ...p, [key]: !p[key] }));

  return (
    <div className="drill-view">
      <div className="drill-header">
        <button className="back-btn" onClick={onBack}>← Back to States</button>
        <span className="drill-title">🏛 {state}</span>
        <span className="drill-count">{rows.length} branches</span>
      </div>

      {Object.entries(tree).map(([city, geos]) => {
        const cityOpen = !!expandedCities[city];
        const cityCount = Object.values(geos).flat().length;
        return (
          <div key={city} className="city-block">
            <div className={`city-header ${cityOpen ? "open" : ""}`} onClick={() => toggleCity(city)}>
              <span style={{ fontSize: 10, color: "#818cf8" }}>{cityOpen ? "▾" : "▸"}</span>
              🏙 {city}
              <span className="city-count">{cityCount}</span>
            </div>
            {cityOpen && Object.entries(geos).map(([geo, geoRows]) => {
              const geoKey = `${city}__${geo}`;
              const geoOpen = !!expandedGeos[geoKey];
              return (
                <div key={geo} className="geo-block">
                  <div className={`geo-header ${geoOpen ? "open" : ""}`} onClick={() => toggleGeo(geoKey)}>
                    <span style={{ fontSize: 10 }}>{geoOpen ? "▾" : "▸"}</span>
                    📍 {geo}
                    <span className="geo-count">{geoRows.length}</span>
                  </div>
                  {geoOpen && (
                    <div className="branches-grid">
                      {geoRows.map((row, i) => <BranchCard key={i} row={row} loginCol={loginCol} disbCol={disbCol} />)}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        );
      })}
    </div>
  );
}

