const getActivityCols = (rows) => {
  if (!rows.length) return { loginCol: null, disbCol: null };
  const keys = Object.keys(rows[0]);
  const loginCol = keys.find((k) => k.toLowerCase().includes("login active"));
  const disbCol = keys.find((k) => k.toLowerCase().includes("disbursal active") || k.toLowerCase().includes("disburs"));
  return { loginCol, disbCol };
};

