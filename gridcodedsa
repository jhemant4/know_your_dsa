        .back-btn:hover { background: #2e3a50; }
        .drill-title { font-size: 16px; font-weight: 700; color: #e2e8f0; }
        .drill-count { margin-left: auto; font-size: 12px; color: #64748b; background: #1e2535; padding: 3px 10px; border-radius: 20px; }

        /* CITY / GEO TREE */
        .city-block { margin: 0 0 8px 0; }
        .city-header {
          display: flex; align-items: center; gap: 8px;
          background: #161b28; border: 1px solid #1e2535; border-radius: 6px;
          padding: 8px 12px; cursor: pointer; user-select: none;
          font-size: 13px; color: #cbd5e1; transition: background .15s; margin-bottom: 6px;
        }
        .city-header:hover { background: #1a2030; }
        .city-header.open { border-color: #818cf8; }
        .city-count { margin-left: auto; font-size: 11px; background: #1e2535; color: #94a3b8; padding: 2px 7px; border-radius: 20px; }

        .geo-block { margin: 0 0 6px 16px; }
        .geo-header {
          display: flex; align-items: center; gap: 8px;
          background: #121722; border: 1px solid #1a2030; border-radius: 6px;
          padding: 7px 12px; cursor: pointer; user-select: none;
          font-size: 12px; color: #94a3b8; transition: background .15s; margin-bottom: 4px;
        }
        .geo-header:hover { background: #161c2a; }
        .geo-header.open { border-color: #4f46e5; color: #c7d2fe; }
        .geo-count { margin-left: auto; font-size: 10px; background: #1a2030; color: #64748b; padding: 1px 6px; border-radius: 20px; }

        /* BRANCH CARDS */
        .branches-grid { display: flex; flex-direction: column; gap: 8px; margin: 0 0 8px 16px; }
        .branch-card { background: #0f1320; border: 1px solid #1e2535; border-radius: 8px; padding: 14px; }
        .branch-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
        .branch-name { font-weight: 600; font-size: 14px; color: #e2e8f0; }
        .branch-code { font-size: 11px; color: #475569; margin-top: 2px; }
        .branch-badges { display: flex; flex-direction: column; gap: 4px; align-items: flex-end; }
        .badge-row { display: flex; align-items: center; gap: 5px; }
        .badge-label { font-size: 10px; color: #475569; }

        .badge { font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 20px; text-transform: uppercase; letter-spacing: .4px; }
        .badge-active { background: #14532d; color: #4ade80; }
        .badge-inactive { background: #450a0a; color: #f87171; }
        .badge-moderate { background: #451a03; color: #fbbf24; }
        .badge-unknown { background: #1e2535; color: #64748b; }

        .branch-hierarchy { display: flex; gap: 14px; font-size: 11px; color: #64748b; margin-bottom: 10px; flex-wrap: wrap; }
        .branch-hierarchy b { color: #94a3b8; }

        .persons-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 10px; }
        .person-card { flex: 1; min-width: 130px; background: #141929; border: 1px solid #1e2a3a; border-radius: 6px; padding: 8px 10px; }
        .person-role { font-size: 9px; text-transform: uppercase; letter-spacing: .6px; color: #475569; margin-bottom: 3px; }
        .person-name { font-size: 12px; font-weight: 600; color: #e2e8f0; margin-bottom: 4px; }
        .person-contact { display: block; font-size: 11px; color: #818cf8; text-decoration: none; margin-top: 2px; }
        .person-contact:hover { text-decoration: underline; }
        .branch-address { font-size: 11px; color: #475569; line-height: 1.4; border-top: 1px solid #1e2535; padding-top: 8px; }

        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: #0f1117; }
        ::-webkit-scrollbar-thumb { background: #252d3d; border-radius: 4px; }
      `}</style>

      <div className="app">
        {/* TOP BAR */}
        <div className="topbar">
          <div className="topbar-brand">Know Your <span>DSA</span></div>
          <label className="upload-btn">
            ⬆ Upload Excel
            <input className="upload-input" type="file" accept=".xlsx,.xls,.csv" onChange={handleFile} />
          </label>
        </div>

        {/* RIBBON */}
        <div className="ribbon">
          <div className="ribbon-card"><div className="ribbon-label">Total Branches</div><div className="ribbon-value">{metrics.total}</div></div>
          <div className="ribbon-card"><div className="ribbon-label">Active</div><div className="ribbon-value clr-active">{metrics.active}</div></div>
          <div className="ribbon-card"><div className="ribbon-label">Inactive</div><div className="ribbon-value clr-inactive">{metrics.inactive}</div></div>
          <div className="ribbon-card"><div className="ribbon-label">Moderate</div><div className="ribbon-value clr-moderate">{metrics.moderate}</div></div>
          <div className="ribbon-card"><div className="ribbon-label">Login Active %</div><div className="ribbon-value clr-pct">{metrics.loginPct}%</div></div>
          <div className="ribbon-card"><div className="ribbon-label">Disb Active %</div><div className="ribbon-value clr-pct">{metrics.disbPct}%</div></div>
        </div>

        {/* BODY */}
        <div className="body">
          {/* SIDEBAR */}
          <div className="sidebar">
            <div>
              <div className="sidebar-label">Search</div>
              <input
                type="text"
                placeholder="Branch, manager, code…"
                value={searchQuery}
                onChange={e => { setSearchQuery(e.target.value); setDrillState(null); }}
              />
            </div>
            <div>
              <div className="sidebar-label">DSA</div>
              <select value={selectedDSA} onChange={e => { setSelectedDSA(e.target.value); setSelectedState("All"); setSelectedCity("All"); setDrillState(null); }}>
                {dsaList.map(d => <option key={d}>{d}</option>)}
              </select>
            </div>
            <div>
              <div className="sidebar-label">State</div>
              <select value={selectedState} onChange={e => { setSelectedState(e.target.value); setSelectedCity("All"); setDrillState(null); }}>
                {stateList.map(s => <option key={s}>{s}</option>)}
              </select>
            </div>
            <div>
              <div className="sidebar-label">City</div>
              <select value={selectedCity} onChange={e => { setSelectedCity(e.target.value); setDrillState(null); }}>
                {cityList.map(c => <option key={c}>{c}</option>)}
              </select>
            </div>
            <div>
              <div className="sidebar-label">Login Status</div>
              <select value={loginStatus} onChange={e => { setLoginStatus(e.target.value); setDrillState(null); }}>
                <option>All</option>
                <option>Active</option>
                <option>Inactive</option>
              </select>
            </div>
            <div>
              <div className="sidebar-label">Disb Status</div>
              <select value={disbStatus} onChange={e => { setDisbStatus(e.target.value); setDrillState(null); }}>
                <option>All</option>
                <option>Active</option>
                <option>Inactive</option>
              </select>
            </div>
          </div>

          {/* MAIN */}
          <div className="main">
            {filtered.length === 0 && <div className="empty">No branches match the selected filters.</div>}

            {filtered.length > 0 && !drillState && (
              <div className="states-grid">
                {Object.entries(stateMap).map(([state, rows]) => (
                  <StateCard
                    key={state}
                    state={state}
                    rows={rows}
                    loginCol={loginCol}
                    disbCol={disbCol}
                    onClick={setDrillState}
                  />
                ))}
              </div>
            )}

            {drillState && (
              <DrillView
                state={drillState}
                rows={drillRows}
                loginCol={loginCol}
                disbCol={disbCol}
                onBack={() => setDrillState(null)}
              />
            )}
          </div>
        </div>
      </div>
    </>
  );
}
