// ---------- Search ----------
function useSearchResults(root, query) {
  return useMemo(() => {
    if (!query || query.trim().length < 2 || !root) return [];
    const q = query.trim().toLowerCase();
    const results = [];
    root.children.forEach((uh) => {
      if (uh.name.toLowerCase().includes(q)) results.push({ kind: "Unit Head", name: uh.name, path: [root.name, uh.name] });
      uh.children.forEach((mgr) => {
        if (mgr.name.toLowerCase().includes(q)) results.push({ kind: "Manager", name: mgr.name, path: [root.name, uh.name, mgr.name] });
        mgr.children.forEach((bm) => {
          if (bm.name.toLowerCase().includes(q) && !bm.selfManaged)
            results.push({ kind: "Branch Manager", name: bm.name, path: [root.name, uh.name, mgr.name, bm.name] });
          bm.children.forEach((branch) => {
            const hay = `${branch.location} ${branch.city} ${branch.state}`.toLowerCase();
            if (hay.includes(q))
              results.push({
                kind: "Branch",
                name: branch.location || branch.city,
                path: [root.name, uh.name, mgr.name, bm.selfManaged ? mgr.name : bm.name],
                branch,
              });
          });
        });
      });
    });
    return results.slice(0, 30);
  }, [root, query]);
}

// ---------- Upload screen ----------
function UploadScreen({ onFile, error, loading }) {
  const inputRef = useRef(null);
  const [dragOver, setDragOver] = useState(false);

  return (
    <div
      style={{
        height: "100%",
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        justifyContent: "center",
        background: COLORS.canvas,
        padding: 20,
      }}
    >
      <div
        onDragOver={(e) => {
          e.preventDefault();
          setDragOver(true);
        }}
        onDragLeave={() => setDragOver(false)}
        onDrop={(e) => {
          e.preventDefault();
          setDragOver(false);
          if (e.dataTransfer.files?.[0]) onFile(e.dataTransfer.files[0]);
        }}
        style={{
          width: "100%",
          maxWidth: 480,
          border: `2px dashed ${dragOver ? COLORS.amber : COLORS.hairline}`,
          borderRadius: 14,
          background: COLORS.white,
          padding: "48px 32px",
          textAlign: "center",
          transition: "border-color 0.15s ease",
        }}
      >
        <div
          style={{
            width: 56,
            height: 56,
            borderRadius: 14,
            background: COLORS.ink,
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
            margin: "0 auto 18px",
          }}
        >
          <Upload size={24} color="#fff" />
        </div>
        <div style={{ fontSize: 18, fontWeight: 700, color: COLORS.ink, marginBottom: 6 }}>
          {loading ? "Reading your file…" : "Upload the branch network file"}
        </div>
        <div style={{ fontSize: 13.5, color: COLORS.slate, marginBottom: 22, lineHeight: 1.5 }}>
          Drop an .xlsx with a <strong>Branch List</strong> sheet (City, State, Location, Unit Head, Manager,
          Branch Manager Name, BM Contact No, Address) and a <strong>Seniors</strong> sheet (Sr No, Name, Reporting
          Mgr, Number, Location).
        </div>
        <button
          onClick={() => inputRef.current?.click()}
          disabled={loading}
          style={{
            background: COLORS.amber,
            color: "#fff",
            border: "none",
            borderRadius: 8,
            padding: "10px 22px",
            fontSize: 14,
            fontWeight: 700,
            cursor: loading ? "default" : "pointer",
            opacity: loading ? 0.6 : 1,
          }}
        >
          {loading ? "Processing…" : "Choose file"}
        </button>
        <input
          ref={inputRef}
          type="file"
