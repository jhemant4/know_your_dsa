  white: "#FFFFFF",
};

// ---------- Data processing ----------
function buildHierarchy(branchRows, seniorRows) {
  // seniorRows: Name -> Reporting Mgr (used to confirm/override links, not required for tree to work)
  const seniorMap = new Map();
  seniorRows.forEach((r) => {
    const name = (r["Name"] || r["Name "] || "").toString().trim();
    const mgr = (r["Reporting Mgr"] || "").toString().trim();
    if (name) seniorMap.set(name, mgr);
  });

  // find the top node: someone who appears as Reporting Mgr for Unit Heads but has no one above them
  // Heuristic: the most common "Reporting Mgr" value among people who are themselves Unit Heads
  const unitHeadNames = new Set(
    branchRows.map((r) => (r["Unit Head"] || "").toString().trim()).filter(Boolean)
  );
  let topCounts = new Map();
  seniorRows.forEach((r) => {
    const name = (r["Name"] || r["Name "] || "").toString().trim();
    const mgr = (r["Reporting Mgr"] || "").toString().trim();
    if (unitHeadNames.has(name) && mgr) {
      topCounts.set(mgr, (topCounts.get(mgr) || 0) + 1);
    }
  });
  let topName = "Top";
  let topCount = 0;
  topCounts.forEach((v, k) => {
    if (v > topCount) {
      topCount = v;
      topName = k;
    }
  });

  // Build tree: top -> unitHead -> manager -> (branchManager or direct) -> branches[]
  const root = { name: topName, level: 0, children: new Map(), branchCount: 0, type: "top" };

  branchRows.forEach((row) => {
    const uh = (row["Unit Head"] || "").toString().trim() || "Unassigned";
    const mgr = (row["Manager"] || "").toString().trim() || "Unassigned";
    const bm = (row["Branch Manager Name"] || "").toString().trim() || mgr;

    if (!root.children.has(uh)) {
      root.children.set(uh, {
        name: uh,
        level: 1,
        type: "unitHead",
        children: new Map(),
        branchCount: 0,
      });
    }
    const uhNode = root.children.get(uh);
    uhNode.branchCount++;
    root.branchCount++;

    if (!uhNode.children.has(mgr)) {
      uhNode.children.set(mgr, {
        name: mgr,
        level: 2,
        type: "manager",
        children: new Map(),
        branchCount: 0,
        reportsTo: seniorMap.get(mgr) || uh,
      });
    }
    const mgrNode = uhNode.children.get(mgr);
    mgrNode.branchCount++;

    const sameBM = bm === mgr;
    const bmKey = sameBM ? "__self__" : bm;

    if (!mgrNode.children.has(bmKey)) {
      mgrNode.children.set(bmKey, {
        name: sameBM ? mgr : bm,
        level: 3,
        type: "branchManager",
        children: [],
        branchCount: 0,
        selfManaged: sameBM,
      });
    }
    const bmNode = mgrNode.children.get(bmKey);
    bmNode.branchCount++;
    bmNode.children.push({
      level: 4,
      type: "branch",
      name: row["Location"] || row["City"] || "Branch",
      city: row["City"] || "",
      state: row["State"] || "",
      location: row["Location"] || "",
      address: row["Address"] || "",
      contact: row["BM Contact No"] || "",
      bmName: bm,
      managerName: mgr,
      unitHeadName: uh,
    });
  });

  return root;
}

function mapToSortedArray(map) {
  return Array.from(map.values()).sort((a, b) => b.branchCount - a.branchCount);
}

// ---------- Small UI atoms ----------
function CountBadge({ n, tone = "ink" }) {
  const bg = tone === "amber" ? COLORS.amber : tone === "forest" ? COLORS.forest : COLORS.ink;
  return (
    <span
      style={{
        fontFamily: "ui-monospace, SFMono-Regular, Menlo, monospace",
        fontSize: 12,
        fontWeight: 600,
        background: bg,
        color: "#fff",
        borderRadius: 5,
        padding: "2px 7px",
        letterSpacing: 0.2,
        minWidth: 28,
        textAlign: "center",
        display: "inline-block",
      }}
    >
      {n}
    </span>
  );
}

function NodeIcon({ type, size = 16 }) {
  const stroke = COLORS.ink;
  if (type === "top") return <Building2 size={size} color={stroke} strokeWidth={2} />;
  if (type === "unitHead") return <User size={size} color={stroke} strokeWidth={2} />;
  if (type === "manager") return <User size={size} color={COLORS.slate} strokeWidth={2} />;
  if (type === "branchManager") return <User size={size} color={COLORS.slate} strokeWidth={2} />;
  return <MapPin size={size} color={COLORS.amber} strokeWidth={2} />;
}

