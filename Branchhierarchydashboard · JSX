            if (e.target.files?.[0]) onFile(e.target.files[0]);
          }}
        />
        {error && (
          <div style={{ marginTop: 16, fontSize: 12.5, color: "#B23B3B", background: "#FBEAEA", padding: "8px 12px", borderRadius: 6 }}>
            {error}
          </div>
        )}
      </div>
    </div>
  );
}

// ---------- Main App ----------
export default function BranchHierarchyDashboard() {
  const [root, setRoot] = useState(null);
  const [error, setError] = useState("");
  const [loading, setLoading] = useState(false);
  const [meta, setMeta] = useState({ branches: 0, seniors: 0 });

  const [selectedUH, setSelectedUH] = useState(null);
  const [selectedMgr, setSelectedMgr] = useState(null);
  const [selectedBM, setSelectedBM] = useState(null);
  const [selectedBranch, setSelectedBranch] = useState(null);
  const [query, setQuery] = useState("");
  const [showSearch, setShowSearch] = useState(false);

  const handleFile = useCallback((file) => {
    setLoading(true);
    setError("");
    const reader = new FileReader();
    reader.onload = (e) => {
      try {
        const data = new Uint8Array(e.target.result);
        const wb = XLSX.read(data, { type: "array" });

        const branchSheetName =
          wb.SheetNames.find((n) => /branch/i.test(n)) || wb.SheetNames[0];
        const seniorSheetName =
          wb.SheetNames.find((n) => /senior/i.test(n)) || wb.SheetNames[1] || wb.SheetNames[0];

        const branchRows = XLSX.utils.sheet_to_json(wb.Sheets[branchSheetName], { defval: "" });
        const seniorRows = XLSX.utils.sheet_to_json(wb.Sheets[seniorSheetName], { defval: "" });

        if (!branchRows.length) {
          setError("Couldn't find any rows in the Branch List sheet. Check the file and try again.");
          setLoading(false);
          return;
        }

        const tree = buildHierarchy(branchRows, seniorRows);
        setRoot(tree);
        setMeta({ branches: branchRows.length, seniors: seniorRows.length });
        setSelectedUH(null);
        setSelectedMgr(null);
        setSelectedBM(null);
        setSelectedBranch(null);
      } catch (err) {
        setError("Couldn't read that file. Make sure it's a valid .xlsx with the expected sheets.");
      }
      setLoading(false);
    };
    reader.onerror = () => {
      setError("Couldn't read that file. Please try again.");
      setLoading(false);
    };
    reader.readAsArrayBuffer(file);
  }, []);

  const unitHeads = useMemo(() => (root ? mapToSortedArray(root.children) : []), [root]);
  const managers = useMemo(
    () => (selectedUH ? mapToSortedArray(selectedUH.children) : []),
    [selectedUH]
  );
  const branchManagers = useMemo(
    () => (selectedMgr ? mapToSortedArray(selectedMgr.children) : []),
    [selectedMgr]
  );
  const branches = useMemo(() => {
    if (selectedBM) return selectedBM.children;
    return [];
  }, [selectedBM]);

  const searchResults = useSearchResults(root, query);

  const breadcrumbPath = useMemo(() => {
    const path = [];
    if (root) path.push(root.name);
    if (selectedUH) path.push(selectedUH.name);
    if (selectedMgr) path.push(selectedMgr.name);
    if (selectedBM) path.push(selectedBM.selfManaged ? selectedMgr.name + " (self)" : selectedBM.name);
    return path;
  }, [root, selectedUH, selectedMgr, selectedBM]);

  const jumpTo = (i) => {
    if (i === 0) {
      setSelectedUH(null);
      setSelectedMgr(null);
      setSelectedBM(null);
    } else if (i === 1) {
      setSelectedMgr(null);
      setSelectedBM(null);
    } else if (i === 2) {
      setSelectedBM(null);
    }
  };

  const goToSearchResult = (res) => {
    const uh = root.children.get(res.path[1]);
    setSelectedUH(uh || null);
    const mgr = uh?.children.get(res.path[2]);
    setSelectedMgr(mgr || null);
    if (res.kind === "Branch" || res.kind === "Branch Manager") {
      const bmKey = res.branch
        ? res.branch.bmName === res.branch.managerName
          ? "__self__"
          : res.branch.bmName
        : res.path[3];
      const bm = mgr?.children.get(bmKey === res.path[3] ? res.path[3] : bmKey);
      setSelectedBM(bm || null);
      if (res.branch) setSelectedBranch(res.branch);
    } else {
      setSelectedBM(null);
    }
    setQuery("");
    setShowSearch(false);
  };

  const reset = () => {
    setRoot(null);
    setError("");
  };

  if (!root) {
    return (
      <div style={{ height: "100vh", width: "100%", fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif" }}>
        <UploadScreen onFile={handleFile} error={error} loading={loading} />
      </div>
    );
  }

  return (
    <div
      style={{
        height: "100vh",
        width: "100%",
        display: "flex",
        flexDirection: "column",
        fontFamily: "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
        background: COLORS.canvas,
        color: COLORS.ink,
        overflow: "hidden",
      }}
    >
      {/* Top bar */}
      <div
        style={{
          display: "flex",
          alignItems: "center",
          justifyContent: "space-between",
          padding: "12px 20px",
          background: COLORS.ink,
          flexShrink: 0,
        }}
      >
        <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
          <Building2 size={20} color={COLORS.amber} />
          <div>
            <div style={{ fontSize: 15, fontWeight: 700, color: "#fff" }}>Branch Network Hierarchy</div>
            <div
              style={{
                fontSize: 11,
                color: "#9AA3B5",
                fontFamily: "ui-monospace, SFMono-Regular, Menlo, monospace",
              }}
            >
              {meta.branches} branches · {meta.seniors} seniors mapped
            </div>
          </div>
        </div>

        <div style={{ display: "flex", alignItems: "center", gap: 10, position: "relative" }}>
          {showSearch ? (
            <div style={{ position: "relative" }}>
              <input
                autoFocus
                value={query}
                onChange={(e) => setQuery(e.target.value)}
                placeholder="Search people or branches…"
                style={{
                  width: 260,
                  padding: "7px 12px 7px 32px",
                  borderRadius: 7,
                  border: "none",
                  fontSize: 13,
                  background: "rgba(255,255,255,0.12)",
                  color: "#fff",
                  outline: "none",
                }}
              />
              <Search size={14} color="#9AA3B5" style={{ position: "absolute", left: 11, top: 9 }} />
              {query.trim().length >= 2 && (
                <div
                  style={{
                    position: "absolute",
                    top: 38,
                    right: 0,
                    width: 320,
                    maxHeight: 360,
                    overflowY: "auto",
                    background: "#fff",
                    borderRadius: 8,
                    boxShadow: "0 8px 24px rgba(20,33,61,0.25)",
                    zIndex: 60,
                  }}
                >
                  {searchResults.length === 0 ? (
                    <div style={{ padding: 14, fontSize: 13, color: COLORS.slate }}>No matches</div>
                  ) : (
                    searchResults.map((r, i) => (
                      <button
                        key={i}
                        onClick={() => goToSearchResult(r)}
                        style={{
                          display: "block",
                          width: "100%",
                          textAlign: "left",
                          padding: "9px 14px",
                          border: "none",
                          borderBottom: `1px solid ${COLORS.hairline}`,
                          background: "transparent",
                          cursor: "pointer",
                        }}
                        onMouseEnter={(e) => (e.currentTarget.style.background = "#F7F5F0")}
                        onMouseLeave={(e) => (e.currentTarget.style.background = "transparent")}
                      >
                        <div style={{ fontSize: 13, fontWeight: 600, color: COLORS.ink }}>{r.name}</div>
                        <div style={{ fontSize: 11, color: COLORS.slate }}>
                          {r.kind} · {r.path.slice(1).join(" › ")}
                        </div>
                      </button>
                    ))
                  )}
                </div>
              )}
            </div>
          ) : (
            <button
              onClick={() => setShowSearch(true)}
              style={{
                display: "flex",
                alignItems: "center",
                gap: 6,
                background: "rgba(255,255,255,0.1)",
                border: "none",
                color: "#fff",
                borderRadius: 7,
                padding: "7px 12px",
                fontSize: 13,
                cursor: "pointer",
              }}
            >
              <Search size={14} />
              Search
            </button>
          )}
          {showSearch && (
            <button
              onClick={() => {
                setShowSearch(false);
                setQuery("");
              }}
              style={{ background: "transparent", border: "none", cursor: "pointer", display: "flex" }}
            >
              <X size={16} color="#9AA3B5" />
            </button>
          )}
          <button
            onClick={reset}
            style={{
              display: "flex",
              alignItems: "center",
              gap: 6,
              background: "transparent",
              border: `1px solid rgba(255,255,255,0.25)`,
              color: "#fff",
              borderRadius: 7,
              padding: "7px 12px",
              fontSize: 13,
              cursor: "pointer",
            }}
          >
            <Upload size={13} />
            New file
          </button>
        </div>
      </div>

      {/* Breadcrumb */}
      <Breadcrumb path={breadcrumbPath} onJump={jumpTo} />

      {/* Columns */}
      <div style={{ flex: 1, display: "flex", overflow: "hidden" }}>
        {/* Top node card (static, level 1) */}
        <div
          style={{
            flex: "0 0 200px",
            minWidth: 180,
            borderRight: `1px solid ${COLORS.hairline}`,
            padding: 16,
            background: "#FBFAF7",
          }}
        >
          <div
            style={{
              fontSize: 10,
              fontWeight: 700,
              letterSpacing: "0.08em",
              textTransform: "uppercase",
              color: COLORS.slate,
              fontFamily: "ui-monospace, SFMono-Regular, Menlo, monospace",
              marginBottom: 10,
            }}
          >
            Level 1 — Top
          </div>
          <div
            style={{
              background: COLORS.ink,
              borderRadius: 10,
              padding: 14,
              color: "#fff",
            }}
          >
            <Building2 size={18} color={COLORS.amber} />
            <div style={{ fontSize: 15, fontWeight: 700, marginTop: 8 }}>{root.name}</div>
            <div style={{ fontSize: 11, color: "#9AA3B5", marginTop: 4 }}>
              {unitHeads.length} unit heads
            </div>
            <div style={{ marginTop: 8 }}>
              <CountBadge n={root.branchCount} tone="amber" />
              <span style={{ fontSize: 10.5, color: "#9AA3B5", marginLeft: 6 }}>branches total</span>
            </div>
          </div>
        </div>

        <LevelColumn
          levelLabel="Level 2 — Unit Heads"
          title={`${unitHeads.length} reporting to ${root.name}`}
          items={unitHeads}
          selectedName={selectedUH?.name}
          onSelect={(item) => {
            setSelectedUH(item);
            setSelectedMgr(null);
            setSelectedBM(null);
          }}
        />

        {selectedUH && (
          <LevelColumn
            levelLabel="Level 3 — Managers"
            title={`under ${selectedUH.name}`}
            items={managers}
            selectedName={selectedMgr?.name}
            onSelect={(item) => {
              setSelectedMgr(item);
              setSelectedBM(null);
            }}
            emptyLabel="No managers recorded"
          />
        )}

        {selectedMgr && (
          <LevelColumn
            levelLabel="Level 4 — Branch Managers"
            title={`under ${selectedMgr.name}`}
            items={branchManagers}
            selectedName={selectedBM?.selfManaged ? selectedMgr.name : selectedBM?.name}
            onSelect={(item) => setSelectedBM(item)}
            emptyLabel="No branch managers recorded"
          />
        )}

        {selectedBM && <BranchColumn branches={branches} onSelectBranch={setSelectedBranch} />}

        {/* filler so layout doesn't look empty before drilling */}
        {!selectedUH && (
          <div
            style={{
              flex: 1,
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              color: COLORS.slate,
              fontSize: 13,
            }}
          >
            Select a Unit Head to drill into their Managers and branches.
          </div>
        )}
      </div>

      <DetailPanel branch={selectedBranch} onClose={() => setSelectedBranch(null)} />
      {selectedBranch && (
        <div
          onClick={() => setSelectedBranch(null)}
          style={{ position: "fixed", inset: 0, background: "rgba(20,33,61,0.25)", zIndex: 40 }}
        />
      )}
    </div>
  );
}
